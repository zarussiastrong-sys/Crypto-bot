# ─────────────────────────────────────────────
#  TEMPORAL ANALYSIS BOT — Environment Config
#  Copy this file to .env and fill in your keys
#  NEVER commit .env to version control
# ─────────────────────────────────────────────

# Optional: Binance API (legacy / fallback)
# Get from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Optional: CoinGecko Pro API key (for extended history / higher limits)
# Get from: https://www.coingecko.com/en/api/pricing
COINGECKO_API_KEY=your_coingecko_api_key_here

# Telegram Bot
# Get from: https://t.me/BotFather  →  /newbot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Optional: Polygon.io (for future stocks support)
POLYGON_API_KEY=your_polygon_api_key_here

# App settings (defaults shown — change if needed)
DEFAULT_SYMBOL=BTCUSDT
DEFAULT_INTERVAL=1d
DEFAULT_BARS=2048
LOG_LEVEL=INFO

# Market data provider: binance or mt5
DATA_PROVIDER=binance

# MT5 credentials (only required when DATA_PROVIDER=mt5)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_MAGIC=900001
MT5_DEVIATION=20
MT5_COMMENT=temporal_bridge

# News filter for high-impact releases (blocks entries around event time)
NEWS_FILTER_ENABLED=1
NEWS_EVENTS_FILE=news_events.json
NEWS_BLOCK_BEFORE_MIN=30
NEWS_BLOCK_AFTER_MIN=30
HIGH_IMPACT_CURRENCIES=USD,EUR,GBP,JPY

# AI guard rails (meta-model heuristic)
AI_MIN_CONFIDENCE=0.52
AI_MAX_RISK_SCORE=0.72
AI_BASE_POSITION_MULT=0.85
AI_MIN_POSITION_MULT=0.20
